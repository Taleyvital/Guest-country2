NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Serveur uniquement — bypass RLS, ne jamais exposer au client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Notifications push (VAPID) ---
# Génère les clés avec :  npx web-push generate-vapid-keys
# La clé PUBLIQUE part au navigateur (préfixe NEXT_PUBLIC_), la PRIVÉE reste côté
# Edge Function (à poser via `supabase secrets set`, PAS dans ce fichier client).
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
